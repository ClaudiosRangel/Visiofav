  status          String        @default("EM_CONFERENCIA") @db.VarChar(20) // EM_CONFERENCIA, APROVADA, REJEITADA
  criadoEm        DateTime      @default(now()) @map("criado_em")
  concluidaEm     DateTime?     @map("concluida_em")


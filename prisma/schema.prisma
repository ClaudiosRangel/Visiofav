generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CORE - MULTIEMPRESA E AUTENTICAÇÃO
// ============================================================================

model Empresa {
  id           String   @id @default(uuid())
  razaoSocial  String   @map("razao_social") @db.VarChar(200)
  nomeFantasia String?  @map("nome_fantasia") @db.VarChar(200)
  cnpj         String   @unique @db.VarChar(20)
  inscEstadual String?  @map("insc_estadual") @db.VarChar(20)
  logradouro   String?  @db.VarChar(200)
  numero       String?  @db.VarChar(20)
  complemento  String?  @db.VarChar(100)
  bairro       String?  @db.VarChar(100)
  cidade       String?  @db.VarChar(100)
  uf           String?  @db.VarChar(2)
  cep          String?  @db.VarChar(10)
  telefone     String?  @db.VarChar(20)
  email        String?  @db.VarChar(200)
  logo         String?  @db.Text
  usaWms       Boolean  @default(false) @map("usa_wms")
  status       Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  // Geolocalização
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)

  // Fiscal
  regimeTributario Int     @default(3) @map("regime_tributario")
  certificadoPfx   String? @map("certificado_pfx") @db.Text
  senhaCertificado String? @map("senha_certificado") @db.VarChar(200)
  ambienteNFe      Int     @default(2) @map("ambiente_nfe")
  serieNFe         Int     @default(1) @map("serie_nfe")
  proximoNumeroNFe Int     @default(1) @map("proximo_numero_nfe")
  serieCTe         Int     @default(1) @map("serie_cte")
  proximoNumeroCTe Int     @default(1) @map("proximo_numero_cte")
  // NFC-e: CSC (Código de Segurança do Contribuinte) para geração do QRCode
  cscIdNfce        String? @map("csc_id_nfce") @db.VarChar(6)
  cscTokenNfce     String? @map("csc_token_nfce") @db.VarChar(36)

  usuarios                  UsuarioEmpresa[]
  produtos                  Produto[]
  fornecedores              Fornecedor[]
  clientes                  Cliente[]
  transportadoras           Transportadora[]
  vendedores                Vendedor[]
  parametros                Parametro[]
  pedidosCompra             PedidoCompra[]
  tabelasPreco              TabelaPreco[]
  pedidosVenda              PedidoVenda[]
  centrosDistribuicao       CentroDistribuicao[]
  estoques                  Estoque[]
  contasPagar               ContaPagar[]
  contasReceber             ContaReceber[]
  nfes                      Nfe[]
  ctes                      Cte[]
  devolucoes                DevolucaoCompra[]
  transferenciasOrigem      TransferenciaEstoque[]     @relation("TransferenciaOrigem")
  transferenciasDestino     TransferenciaEstoque[]     @relation("TransferenciaDestino")
  agendaWms                 AgendaWms[]
  apiKeys                   ApiKey[]
  webhooks                  WebhookConfig[]
  fichasOperacionais        FichaOperacional[]
  deparasProdutoFornecedor  DeparaProdutoFornecedor[]
  veiculosPatio             VeiculoPatio[]
  contratosArmazenagem      ContratoArmazenagem[]
  zonasPicking              ZonaPicking[]
  solicitacoesTransferencia SolicitacaoTransferencia[]
  configsConferenciaProduto ConfigConferenciaProduto[]
  configIntegracao          ConfigIntegracao?
  configEmailFiscal         ConfigEmailFiscal?
  pendenciasCce             PendenciaCce[]

  // Módulo Fiscal
  regrasTributarias         RegraTributaria[]
  documentosFiscais         DocumentoFiscal[]
  certificadosDigitais      CertificadoDigital[]
  filasContingencia         FilaContingencia[]
  logsContingencia          LogContingencia[]
  apuracoesFiscais          ApuracaoFiscal[]
  naturezasOperacao         NaturezaOperacao[]
  gnres                     Gnre[]
  xmlsImportados            XmlImportado[]
  auditoriasFiscais         AuditoriaFiscal[]

  // Configurações de Conferência
  conferenciaQuantidadeCega Boolean @default(false) @map("conferencia_quantidade_cega")
  conferenciaLoteCega       Boolean @default(false) @map("conferencia_lote_cega")
  permiteRecebimentoParcial Boolean @default(false) @map("permite_recebimento_parcial")

  @@map("empresa")
}

model Usuario {
  id            String   @id @default(uuid())
  nome          String   @db.VarChar(150)
  email         String   @unique @db.VarChar(200)
  senha         String   @db.VarChar(200)
  perfil        String   @default("OPERADOR") @db.VarChar(30)
  status        Boolean  @default(true)
  senhaAlterada Boolean  @default(false) @map("senha_alterada")
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")

  empresas                UsuarioEmpresa[]
  divergenciasAutorizadas DivergenciaConferencia[]
  refreshTokens           RefreshToken[]

  @@map("usuario")
}

/// Refresh tokens para renovação segura de access tokens.
/// Permite revogação individual e rotação automática.
model RefreshToken {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  token     String   @unique @db.VarChar(200)
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@index([token])
  @@index([usuarioId])
  @@map("refresh_token")
}

/// Log de eventos de segurança (login, logout, acesso negado, ações admin).
/// Mantido separado da auditoria operacional para análise de ameaças.
model SecurityAuditLog {
  id        String   @id @default(uuid())
  tipo      String   @db.VarChar(50)
  usuarioId String?  @map("usuario_id")
  email     String?  @db.VarChar(200)
  ip        String   @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(300)
  detalhes  String?  @db.Text
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@index([tipo, criadoEm])
  @@index([usuarioId])
  @@index([ip])
  @@map("security_audit_log")
}

model UsuarioEmpresa {
  usuarioId String  @map("usuario_id")
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  empresaId String  @map("empresa_id")
  empresa   Empresa @relation(fields: [empresaId], references: [id])
  modulos   String  @default("*") @db.VarChar(200) // "COMPRAS,VENDAS,WMS" ou "*" para todos

  @@id([usuarioId, empresaId])
  @@map("usuario_empresa")
}

model PreferenciaUsuario {
  id           String   @id @default(uuid())
  usuarioId    String   @unique @map("usuario_id")
  tema         String   @default("auto") @db.VarChar(10)
  idioma       String   @default("pt-BR") @db.VarChar(10)
  densidade    String   @default("normal") @db.VarChar(15)
  formatoData  String   @default("DD/MM/YYYY") @map("formato_data") @db.VarChar(15)
  notifSons    Boolean  @default(true) @map("notif_sons")
  notifPush    Boolean  @default(true) @map("notif_push")
  notifEmail   Boolean  @default(true) @map("notif_email")
  moduloPadrao String?  @map("modulo_padrao") @db.VarChar(30)
  tamanhoFonte String   @default("medio") @map("tamanho_fonte") @db.VarChar(10)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  @@map("preferencia_usuario")
}

// ============================================================================
// CADASTROS BASE
// ============================================================================

model Parametro {
  id           String   @id @default(uuid())
  empresaId    String   @map("empresa_id")
  empresa      Empresa  @relation(fields: [empresaId], references: [id])
  chave        String   @db.VarChar(100)
  valor        String   @db.Text
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  @@unique([empresaId, chave])
  @@map("parametro")
}

model Fornecedor {
  id           String   @id @default(uuid())
  empresaId    String   @map("empresa_id")
  empresa      Empresa  @relation(fields: [empresaId], references: [id])
  razaoSocial  String   @map("razao_social") @db.VarChar(200)
  nomeFantasia String?  @map("nome_fantasia") @db.VarChar(200)
  cnpj         String   @db.VarChar(20)
  inscEstadual String?  @map("insc_estadual") @db.VarChar(20)
  logradouro   String?  @db.VarChar(200)
  numero       String?  @db.VarChar(20)
  complemento  String?  @db.VarChar(100)
  bairro       String?  @db.VarChar(100)
  cidade       String?  @db.VarChar(100)
  uf           String?  @db.VarChar(2)
  cep          String?  @db.VarChar(10)
  telefone     String?  @db.VarChar(20)
  email        String?  @db.VarChar(200)
  status       Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  pedidosCompra  PedidoCompra[]
  contasPagar    ContaPagar[]
  deparasProduto DeparaProdutoFornecedor[]

  @@unique([empresaId, cnpj])
  @@map("fornecedor")
}

model Cliente {
  id           String   @id @default(uuid())
  empresaId    String   @map("empresa_id")
  empresa      Empresa  @relation(fields: [empresaId], references: [id])
  razaoSocial  String   @map("razao_social") @db.VarChar(200)
  nomeFantasia String?  @map("nome_fantasia") @db.VarChar(200)
  cpfCnpj      String   @map("cpf_cnpj") @db.VarChar(20)
  inscEstadual String?  @map("insc_estadual") @db.VarChar(20)
  logradouro   String?  @db.VarChar(200)
  numero       String?  @db.VarChar(20)
  complemento  String?  @db.VarChar(100)
  bairro       String?  @db.VarChar(100)
  cidade       String?  @db.VarChar(100)
  uf           String?  @db.VarChar(2)
  cep          String?  @db.VarChar(10)
  telefone     String?  @db.VarChar(20)
  email        String?  @db.VarChar(200)
  status       Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")
  rotaId       String?  @map("rota_id")

  // Geolocalização
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)

  pedidosVenda         PedidoVenda[]
  contasReceber        ContaReceber[]
  contratosArmazenagem ContratoArmazenagem[] @relation("ContratosArmazenagemCliente")

  @@unique([empresaId, cpfCnpj])
  @@map("cliente")
}

model Transportadora {
  id           String   @id @default(uuid())
  empresaId    String   @map("empresa_id")
  empresa      Empresa  @relation(fields: [empresaId], references: [id])
  razaoSocial  String   @map("razao_social") @db.VarChar(200)
  nomeFantasia String?  @map("nome_fantasia") @db.VarChar(200)
  cnpj         String   @db.VarChar(20)
  inscEstadual String?  @map("insc_estadual") @db.VarChar(20)
  logradouro   String?  @db.VarChar(200)
  numero       String?  @db.VarChar(20)
  cidade       String?  @db.VarChar(100)
  uf           String?  @db.VarChar(2)
  cep          String?  @db.VarChar(10)
  telefone     String?  @db.VarChar(20)
  status       Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  @@unique([empresaId, cnpj])
  @@map("transportadora")
}

model Produto {
  id               String   @id @default(uuid())
  empresaId        String   @map("empresa_id")
  empresa          Empresa  @relation(fields: [empresaId], references: [id])
  codigo           String   @db.VarChar(60)
  nome             String   @db.VarChar(200)
  descricao        String?  @db.Text
  unidade          String   @default("UN") @db.VarChar(6)
  precoBase        Decimal  @default(0) @map("preco_base") @db.Decimal(12, 4)
  status           Boolean  @default(true)
  imagemUrl        String?  @map("imagem_url") @db.Text
  shelfLifeMinimo  Int?     @map("shelf_life_minimo")
  curvaAbc         String?  @map("curva_abc") @db.VarChar(1)
  classificacaoPcp String?  @map("classificacao_pcp") @db.VarChar(20) // MATERIA_PRIMA, INTERMEDIARIO, PRODUTO_ACABADO, EMBALAGEM, INSUMO
  tipoFisico       String?  @map("tipo_fisico") @db.VarChar(20) // UNIDADE_PADRAO, FISICO_LINEAR, FISICO_SUPERFICIAL, LIQUIDO, PESO
  exigeLote        Boolean  @default(false) @map("exige_lote")
  criadoEm         DateTime @default(now()) @map("criado_em")
  atualizadoEm     DateTime @updatedAt @map("atualizado_em")

  // Fiscal
  ncm          String? @db.VarChar(8)
  cfopEstadual String? @map("cfop_estadual") @db.VarChar(4)
  cfopInterest String? @map("cfop_interest") @db.VarChar(4)
  cst          String? @db.VarChar(3)
  csosn        String? @db.VarChar(4)
  aliqICMS     Decimal @default(0) @map("aliq_icms") @db.Decimal(5, 2)
  aliqIPI      Decimal @default(0) @map("aliq_ipi") @db.Decimal(5, 2)
  cstPIS       String? @map("cst_pis") @db.VarChar(2)
  aliqPIS      Decimal @default(0) @map("aliq_pis") @db.Decimal(5, 2)
  cstCOFINS    String? @map("cst_cofins") @db.VarChar(2)
  aliqCOFINS   Decimal @default(0) @map("aliq_cofins") @db.Decimal(5, 2)
  origemProd   Int     @default(0) @map("origem_prod")
  cEAN         String? @map("c_ean") @db.VarChar(14)

  itensPedidoCompra             ItemPedidoCompra[]
  itensPedidoVenda              ItemPedidoVenda[]
  itensNfe                      ItemNfe[]
  itensDevolucao                ItemDevolucaoCompra[]
  itensTransferencia            ItemTransferencia[]
  estoques                      Estoque[]
  saldosEndereco                SaldoEndereco[]
  deparasFornecedor             DeparaProdutoFornecedor[]
  configsConferenciaProduto     ConfigConferenciaProduto[]
  movimentacoesFaturaveis       MovimentacaoFaturavel[]
  itensSubOnda                  ItemSubOnda[]
  itensSolicitacaoTransferencia ItemSolicitacaoTransferencia[]
  mercadoriasTransito           MercadoriaTransito[]
  itensDocumentoFiscal          ItemDocumentoFiscal[]

  @@unique([empresaId, codigo])
  @@map("produto")
}

model Vendedor {
  id           String   @id @default(uuid())
  empresaId    String   @map("empresa_id")
  empresa      Empresa  @relation(fields: [empresaId], references: [id])
  nome         String   @db.VarChar(150)
  cpf          String   @db.VarChar(14)
  comissao     Decimal  @db.Decimal(5, 2)
  status       Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  pedidosCompra PedidoCompra[]
  pedidosVenda  PedidoVenda[]

  @@unique([empresaId, cpf])
  @@map("vendedor")
}

// ============================================================================
// COMPRAS
// ============================================================================

model PedidoCompra {
  id                 String     @id @default(uuid())
  empresaId          String     @map("empresa_id")
  empresa            Empresa    @relation(fields: [empresaId], references: [id])
  numero             Int
  fornecedorId       String     @map("fornecedor_id")
  fornecedor         Fornecedor @relation(fields: [fornecedorId], references: [id])
  vendedorId         String?    @map("vendedor_id")
  vendedor           Vendedor?  @relation(fields: [vendedorId], references: [id])
  dataEntrega        DateTime?  @map("data_entrega")
  valorTotal         Decimal    @default(0) @map("valor_total") @db.Decimal(12, 2)
  status             String     @default("RASCUNHO") @db.VarChar(20)
  motivoCancelamento String?    @map("motivo_cancelamento") @db.Text
  criadoEm           DateTime   @default(now()) @map("criado_em")
  atualizadoEm       DateTime   @updatedAt @map("atualizado_em")

  itens           ItemPedidoCompra[]
  compraEfetivada CompraEfetivada?

  @@unique([empresaId, numero])
  @@map("pedido_compra")
}

model ItemPedidoCompra {
  id             String       @id @default(uuid())
  pedidoCompraId String       @map("pedido_compra_id")
  pedidoCompra   PedidoCompra @relation(fields: [pedidoCompraId], references: [id], onDelete: Cascade)
  produtoId      String       @map("produto_id")
  produto        Produto      @relation(fields: [produtoId], references: [id])
  quantidade     Decimal      @db.Decimal(12, 4)
  precoUnitario  Decimal      @map("preco_unitario") @db.Decimal(12, 4)
  unidade        String       @default("UN") @db.VarChar(6)
  classificacao  String       @default("REVENDA") @db.VarChar(20)
  valorTotal     Decimal      @map("valor_total") @db.Decimal(12, 2)

  @@map("item_pedido_compra")
}

model CompraEfetivada {
  id             String       @id @default(uuid())
  empresaId      String       @map("empresa_id")
  pedidoCompraId String       @unique @map("pedido_compra_id")
  pedidoCompra   PedidoCompra @relation(fields: [pedidoCompraId], references: [id])
  dataEfetivacao DateTime     @default(now()) @map("data_efetivacao")
  dataEntrega    DateTime?    @map("data_entrega")
  xmlNfe         String?      @map("xml_nfe") @db.Text
  valorTotal     Decimal      @map("valor_total") @db.Decimal(12, 2)
  criadoEm       DateTime     @default(now()) @map("criado_em")

  devolucoes        DevolucaoCompra[]
  contasPagar       ContaPagar[]
  documentosFiscais DocumentoFiscal[]

  @@map("compra_efetivada")
}

model DevolucaoCompra {
  id                String          @id @default(uuid())
  empresaId         String          @map("empresa_id")
  empresa           Empresa         @relation(fields: [empresaId], references: [id])
  compraEfetivadaId String          @map("compra_efetivada_id")
  compraEfetivada   CompraEfetivada @relation(fields: [compraEfetivadaId], references: [id])
  dataDevolucao     DateTime        @default(now()) @map("data_devolucao")
  valorTotal        Decimal         @map("valor_total") @db.Decimal(12, 2)
  criadoEm          DateTime        @default(now()) @map("criado_em")

  itens ItemDevolucaoCompra[]

  @@map("devolucao_compra")
}

model ItemDevolucaoCompra {
  id                String          @id @default(uuid())
  devolucaoCompraId String          @map("devolucao_compra_id")
  devolucaoCompra   DevolucaoCompra @relation(fields: [devolucaoCompraId], references: [id], onDelete: Cascade)
  produtoId         String          @map("produto_id")
  produto           Produto         @relation(fields: [produtoId], references: [id])
  quantidade        Decimal         @db.Decimal(12, 4)
  precoUnitario     Decimal         @map("preco_unitario") @db.Decimal(12, 4)

  @@map("item_devolucao_compra")
}

model TransferenciaEstoque {
  id                String   @id @default(uuid())
  empresaOrigemId   String   @map("empresa_origem_id")
  empresaOrigem     Empresa  @relation("TransferenciaOrigem", fields: [empresaOrigemId], references: [id])
  empresaDestinoId  String   @map("empresa_destino_id")
  empresaDestino    Empresa  @relation("TransferenciaDestino", fields: [empresaDestinoId], references: [id])
  dataTransferencia DateTime @default(now()) @map("data_transferencia")
  status            String   @default("PENDENTE") @db.VarChar(20)
  criadoEm          DateTime @default(now()) @map("criado_em")

  itens ItemTransferencia[]

  @@map("transferencia_estoque")
}

model ItemTransferencia {
  id              String               @id @default(uuid())
  transferenciaId String               @map("transferencia_id")
  transferencia   TransferenciaEstoque @relation(fields: [transferenciaId], references: [id], onDelete: Cascade)
  produtoId       String               @map("produto_id")
  produto         Produto              @relation(fields: [produtoId], references: [id])
  quantidade      Decimal              @db.Decimal(12, 4)

  @@map("item_transferencia")
}

// ============================================================================
// VENDAS
// ============================================================================

model TabelaPreco {
  id           String   @id @default(uuid())
  empresaId    String   @map("empresa_id")
  empresa      Empresa  @relation(fields: [empresaId], references: [id])
  nome         String   @db.VarChar(100)
  status       Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  condicoes    CondicaoPagamento[]
  pedidosVenda PedidoVenda[]

  @@map("tabela_preco")
}

model CondicaoPagamento {
  id             String      @id @default(uuid())
  tabelaPrecoId  String      @map("tabela_preco_id")
  tabelaPreco    TabelaPreco @relation(fields: [tabelaPrecoId], references: [id], onDelete: Cascade)
  formaPagamento String      @db.VarChar(30)
  parcelas       Int         @default(1)
  percentual     Decimal     @db.Decimal(6, 2)

  @@map("condicao_pagamento")
}

model PedidoVenda {
  id                 String      @id @default(uuid())
  empresaId          String      @map("empresa_id")
  empresa            Empresa     @relation(fields: [empresaId], references: [id])
  numero             Int
  clienteId          String      @map("cliente_id")
  cliente            Cliente     @relation(fields: [clienteId], references: [id])
  vendedorId         String?     @map("vendedor_id")
  vendedor           Vendedor?   @relation(fields: [vendedorId], references: [id])
  tabelaPrecoId      String      @map("tabela_preco_id")
  tabelaPreco        TabelaPreco @relation(fields: [tabelaPrecoId], references: [id])
  condicaoPagId      String?     @map("condicao_pag_id")
  rotaId             String?     @map("rota_id")
  valorTotal         Decimal     @default(0) @map("valor_total") @db.Decimal(12, 2)
  status             String      @default("RASCUNHO") @db.VarChar(20)
  motivoCancelamento String?     @map("motivo_cancelamento") @db.Text
  criadoEm           DateTime    @default(now()) @map("criado_em")
  atualizadoEm       DateTime    @updatedAt @map("atualizado_em")

  itens          ItemPedidoVenda[]
  vendaEfetivada VendaEfetivada?

  @@unique([empresaId, numero])
  @@map("pedido_venda")
}

model ItemPedidoVenda {
  id            String      @id @default(uuid())
  pedidoVendaId String      @map("pedido_venda_id")
  pedidoVenda   PedidoVenda @relation(fields: [pedidoVendaId], references: [id], onDelete: Cascade)
  produtoId     String      @map("produto_id")
  produto       Produto     @relation(fields: [produtoId], references: [id])

  status          String                 @default("PENDENTE") @db.VarChar(20) // PENDENTE, AUTORIZADA, REJEITADA
  motivoRejeicao  String?                @map("motivo_rejeicao") @db.Text
  criadoEm        DateTime               @default(now()) @map("criado_em")


model MapaCarregamento {
  id                 String    @id @default(uuid())
  empresaId          String    @map("empresa_id")
  numero             Int
  rotaId             String?   @map("rota_id")
  veiculoPlaca       String    @map("veiculo_placa") @db.VarChar(10)
  motorista          String?   @db.VarChar(200)
  motoristaCpf       String?   @map("motorista_cpf") @db.VarChar(14)
  observacoes        String?   @db.Text
  status             String    @default("AGUARDANDO_SEPARACAO") @db.VarChar(30)
  motivoCancelamento String?   @map("motivo_cancelamento") @db.Text
  criadoPorId        String    @map("criado_por_id")
  canceladoPorId     String?   @map("cancelado_por_id")
  fechadoPorId       String?   @map("fechado_por_id")
  emissaoEm          DateTime  @default(now()) @map("emissao_em")
  finalizadoEm       DateTime? @map("finalizado_em")
  canceladoEm        DateTime? @map("cancelado_em")
  criadoEm           DateTime  @default(now()) @map("criado_em")
  atualizadoEm       DateTime  @updatedAt @map("atualizado_em")

  // Geolocalização — sequência de entrega
  distanciaTotalKm Decimal? @map("distancia_total_km") @db.Decimal(10, 2)
  sequenciaValida  Boolean  @default(false) @map("sequencia_valida")

  nfs MapaCarregamentoNf[]

  @@unique([empresaId, numero])
  @@map("mapa_carregamento")
}

model MapaCarregamentoNf {
  id                 String           @id @default(uuid())
  mapaCarregamentoId String           @map("mapa_carregamento_id")
  mapaCarregamento   MapaCarregamento @relation(fields: [mapaCarregamentoId], references: [id], onDelete: Cascade)
  nfeId              String           @map("nfe_id")
  statusEntrega      String?          @map("status_entrega") @db.VarChar(20)
  motivoDevolucao    String?          @map("motivo_devolucao") @db.Text

  // Geolocalização — sequência de entrega
  ordemEntrega       Int?     @map("ordem_entrega")
  distanciaParcialKm Decimal? @map("distancia_parcial_km") @db.Decimal(10, 2)

  @@unique([mapaCarregamentoId, nfeId])
  @@map("mapa_carregamento_nf")
}

// ============================================================================
// DE-PARA FORNECEDOR x PRODUTO
// ============================================================================

model DeparaProdutoFornecedor {
  id                      String   @id @default(uuid())
  empresaId               String   @map("empresa_id")
  fornecedorId            String   @map("fornecedor_id")
  codigoProdutoFornecedor String   @map("codigo_produto_fornecedor") @db.VarChar(60)
  descricaoFornecedor     String?  @map("descricao_fornecedor") @db.VarChar(200)
  produtoId               String   @map("produto_id")
  skuId                   String?  @map("sku_id")
  unidadeFornecedor       String   @map("unidade_fornecedor") @db.VarChar(6)
  fatorConversao          Decimal  @default(1) @map("fator_conversao") @db.Decimal(12, 4)
  cEAN                    String?  @map("c_ean") @db.VarChar(14)
  cEANTrib                String?  @map("c_ean_trib") @db.VarChar(14)
  status                  Boolean  @default(true)
  criadoEm                DateTime @default(now()) @map("criado_em")
  atualizadoEm            DateTime @updatedAt @map("atualizado_em")

  empresa    Empresa    @relation(fields: [empresaId], references: [id])
  fornecedor Fornecedor @relation(fields: [fornecedorId], references: [id])
  produto    Produto    @relation(fields: [produtoId], references: [id])

  @@unique([empresaId, fornecedorId, codigoProdutoFornecedor])
  @@index([empresaId, fornecedorId])
  @@index([produtoId])
  @@map("depara_produto_fornecedor")
}

// ============================================================================
// PCP — PLANEJAMENTO E CONTROLE DA PRODUÇÃO
// ============================================================================

model CentroProducao {
  id             String   @id @default(uuid())
  empresaId      String   @map("empresa_id")
  codigo         String   @db.VarChar(20)
  descricao      String   @db.VarChar(200)
  tipo           String   @db.VarChar(20) // MAQUINA, SETOR, LINHA
  tipoMaquina    String?  @map("tipo_maquina") @db.VarChar(20) // IMPRESSAO, ACABAMENTO, CORTADEIRA, COLAGEM, VERNIZ
  capacidadeHora Decimal? @map("capacidade_hora") @db.Decimal(12, 4)
  custoHora      Decimal? @map("custo_hora") @db.Decimal(12, 4)
  posicao        Int      @default(0)
  status         Boolean  @default(true)
  criadoEm       DateTime @default(now()) @map("criado_em")
  atualizadoEm   DateTime @updatedAt @map("atualizado_em")

  recursos      RecursoProducao[]
  etapasRoteiro EtapaRoteiro[]
  etapasOp      EtapaOrdemProducao[]
  apontamentos  ApontamentoProducao[]

  @@unique([empresaId, codigo])
  @@map("centro_producao")
}

model RecursoProducao {
  id               String          @id @default(uuid())
  empresaId        String          @map("empresa_id")
  codigo           String          @db.VarChar(20)
  descricao        String          @db.VarChar(200)
  tipo             String          @db.VarChar(20) // OPERADOR, FERRAMENTA, MOLDE, FACA, OUTRO
  centroProducaoId String?         @map("centro_producao_id")
  centroProducao   CentroProducao? @relation(fields: [centroProducaoId], references: [id])
  custoHora        Decimal?        @map("custo_hora") @db.Decimal(12, 4)
  status           Boolean         @default(true)
  criadoEm         DateTime        @default(now()) @map("criado_em")
  atualizadoEm     DateTime        @updatedAt @map("atualizado_em")

  etapasRoteiro EtapaRoteiro[]
  etapasOp      EtapaOrdemProducao[]

  @@unique([empresaId, codigo])
  @@map("recurso_producao")
}

model TurnoProducao {
  id             String   @id @default(uuid())
  empresaId      String   @map("empresa_id")
  codigo         String   @db.VarChar(10)
  descricao      String   @db.VarChar(100)
  horaInicio     String   @map("hora_inicio") @db.VarChar(5) // "08:00"
  horaFim        String   @map("hora_fim") @db.VarChar(5) // "17:00"
  diasSemana     Int[]    @map("dias_semana") // [1,2,3,4,5] = seg-sex
  duracaoMinutos Int      @map("duracao_minutos")
  status         Boolean  @default(true)
  criadoEm       DateTime @default(now()) @map("criado_em")
  atualizadoEm   DateTime @updatedAt @map("atualizado_em")

  @@unique([empresaId, codigo])
  @@map("turno_producao")
}

model EstruturaProduto {
  id           String   @id @default(uuid())
  empresaId    String   @map("empresa_id")
  produtoId    String   @map("produto_id")
  versao       Int      @default(1)
  descricao    String?  @db.VarChar(200)
  rendimento   Decimal  @default(1) @db.Decimal(12, 4)
  status       String   @default("RASCUNHO") @db.VarChar(10) // ATIVA, INATIVA, RASCUNHO
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  itens          ItemEstrutura[]
  ordensProducao OrdemProducao[]

  @@unique([empresaId, produtoId, versao])
  @@map("estrutura_produto")
}

model ItemEstrutura {
  id                  String           @id @default(uuid())
  estruturaProdutoId  String           @map("estrutura_produto_id")
  estruturaProduto    EstruturaProduto @relation(fields: [estruturaProdutoId], references: [id], onDelete: Cascade)
  produtoComponenteId String           @map("produto_componente_id")
  quantidade          Decimal          @db.Decimal(12, 4)
  unidadeMedida       String           @map("unidade_medida") @db.VarChar(10)
  percentualPerda     Decimal          @default(0) @map("percentual_perda") @db.Decimal(5, 2)
  quantidadeLiquida   Decimal          @map("quantidade_liquida") @db.Decimal(12, 4) // quantidade * (1 + percentualPerda/100)
  sequencia           Int              @default(1)
  observacao          String?          @db.Text
  // Campos específicos indústria gráfica
  aproveitamento      Int? // Itens por folha/puxada (imposição) — ou peças por barra/chapa
  perdaFixaAcerto     Decimal?         @map("perda_fixa_acerto") @db.Decimal(12, 4) // Unidades fixas gastas no setup (independe da tiragem)
  coberturaPercent    Decimal?         @map("cobertura_percent") @db.Decimal(5, 2) // % cobertura/aplicação (tintas, vernizes, revestimentos)
  tipoComponente      String?          @map("tipo_componente") @db.VarChar(20) // MATERIA_PRIMA, COMPONENTE, INSUMO, EMBALAGEM

  @@map("item_estrutura")
}

model RoteiroProducao {
  id           String   @id @default(uuid())
  empresaId    String   @map("empresa_id")
  produtoId    String   @map("produto_id")
  versao       Int      @default(1)
  descricao    String?  @db.VarChar(200)
  status       String   @default("RASCUNHO") @db.VarChar(10) // ATIVO, INATIVO, RASCUNHO
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  etapas EtapaRoteiro[]

  @@unique([empresaId, produtoId, versao])
  @@map("roteiro_producao")
}

model EtapaRoteiro {
  id                   String           @id @default(uuid())
  roteiroProducaoId    String           @map("roteiro_producao_id")
  roteiroProducao      RoteiroProducao  @relation(fields: [roteiroProducaoId], references: [id], onDelete: Cascade)
  sequencia            Int
  descricao            String           @db.VarChar(200)
  centroProducaoId     String           @map("centro_producao_id")
  centroProducao       CentroProducao   @relation(fields: [centroProducaoId], references: [id])
  tempoSetupMinutos    Decimal          @default(0) @map("tempo_setup_minutos") @db.Decimal(10, 2)
  tempoOperacaoMinutos Decimal          @default(0) @map("tempo_operacao_minutos") @db.Decimal(10, 2)
  tempoEsperaMinutos   Decimal          @default(0) @map("tempo_espera_minutos") @db.Decimal(10, 2)
  tempoTotalMinutos    Decimal          @default(0) @map("tempo_total_minutos") @db.Decimal(10, 2)
  recursoId            String?          @map("recurso_id")
  recurso              RecursoProducao? @relation(fields: [recursoId], references: [id])
  observacao           String?          @db.Text

  @@map("etapa_roteiro")
}

model OrdemProducao {
  id                  String            @id @default(uuid())
  empresaId           String            @map("empresa_id")
  numero              Int
  produtoId           String?           @map("produto_id")
  estruturaProdutoId  String?           @map("estrutura_produto_id")
  estruturaProduto    EstruturaProduto? @relation(fields: [estruturaProdutoId], references: [id])
  quantidade          Decimal           @db.Decimal(12, 4)
  unidadeMedida       String            @map("unidade_medida") @db.VarChar(10)
  quantidadeProduzida Decimal           @default(0) @map("quantidade_produzida") @db.Decimal(12, 4)
  quantidadeRejeitada Decimal           @default(0) @map("quantidade_rejeitada") @db.Decimal(12, 4)
  status              String            @default("RASCUNHO") @db.VarChar(20) // RASCUNHO, PLANEJADA, PROGRAMADA, LIBERADA, EM_PRODUCAO, CONCLUIDA, CANCELADA
  prioridade          String            @default("NORMAL") @db.VarChar(10) // BAIXA, NORMAL, ALTA, URGENTE
  dataEmissao         DateTime          @default(now()) @map("data_emissao")
  dataEntregaPrevista DateTime?         @map("data_entrega_prevista")
  dataEntregaOriginal DateTime?         @map("data_entrega_original")
  vezesPostergada     Int               @default(0) @map("vezes_postergada")
  dataInicioPrevista  DateTime?         @map("data_inicio_prevista")
  dataFimPrevista     DateTime?         @map("data_fim_prevista")
  dataInicioReal      DateTime?         @map("data_inicio_real")
  dataFimReal         DateTime?         @map("data_fim_real")
  pedidoVendaId       String?           @map("pedido_venda_id")
  clienteId           String?           @map("cliente_id")
  lote                String?           @db.VarChar(50)
  cor                 String?           @db.VarChar(50)
  grupoOpId           String?           @map("grupo_op_id")
  quantidadeExcedente Decimal           @default(0) @map("quantidade_excedente") @db.Decimal(12, 4)
  motivoCancelamento  String?           @map("motivo_cancelamento") @db.Text
  observacoes         String?           @db.Text
  referenciaExterna   String?           @map("referencia_externa") @db.VarChar(50) // Número da OP no sistema externo
  origemImportacao    String?           @map("origem_importacao") @db.VarChar(30) // PDF_GPRINT, MANUAL, etc.
  criadoPorId         String?           @map("criado_por_id")
  criadoEm            DateTime          @default(now()) @map("criado_em")
  atualizadoEm        DateTime          @updatedAt @map("atualizado_em")

  itens               ItemOrdemProducao[]
  etapas              EtapaOrdemProducao[]
  apontamentos        ApontamentoProducao[]
  logs                LogOrdemProducao[]
  liberacoes          LiberacaoMaterial[]
  variacoes           VariacaoOrdemProducao[]
  programacoesEntrega ProgramacaoEntrega[]

  @@unique([empresaId, numero])
  @@map("ordem_producao")
}

// Multi-item: variações de cor/modelo dentro da mesma OP (ex: 3 cores de caixa)
model VariacaoOrdemProducao {
  id              String        @id @default(uuid())
  ordemProducaoId String        @map("ordem_producao_id")
  ordemProducao   OrdemProducao @relation(fields: [ordemProducaoId], references: [id], onDelete: Cascade)
  codigoProduto   String        @map("codigo_produto") @db.VarChar(60)
  descricao       String        @db.VarChar(200)
  quantidade      Decimal       @db.Decimal(12, 4)
  cor             String?       @db.VarChar(50)
  observacao      String?       @db.Text
  sequencia       Int           @default(1)

  @@map("variacao_ordem_producao")
}

// Entregas parciais programadas (ex: 6.900 em 04/05, 4.600 em 10/05)
model ProgramacaoEntrega {
  id              String        @id @default(uuid())
  ordemProducaoId String        @map("ordem_producao_id")
  ordemProducao   OrdemProducao @relation(fields: [ordemProducaoId], references: [id], onDelete: Cascade)
  dataEntrega     DateTime      @map("data_entrega")
  quantidade      Decimal       @db.Decimal(12, 4)
  codigoPedido    String?       @map("codigo_pedido") @db.VarChar(30)
  status          String        @default("PENDENTE") @db.VarChar(20) // PENDENTE, PRODUZIDO, EXPEDIDO
  observacao      String?       @db.Text

  @@map("programacao_entrega")
}

model ItemOrdemProducao {
  id                  String        @id @default(uuid())
  ordemProducaoId     String        @map("ordem_producao_id")
  ordemProducao       OrdemProducao @relation(fields: [ordemProducaoId], references: [id], onDelete: Cascade)
  produtoComponenteId String?       @map("produto_componente_id")
  descricaoProduto    String        @map("descricao_produto") @db.VarChar(200)
  descricaoExterna    String?       @map("descricao_externa") @db.VarChar(300) // Descrição original do sistema externo
  quantidade          Decimal       @db.Decimal(12, 4)
  unidadeMedida       String        @map("unidade_medida") @db.VarChar(10)
  tipoMaterial        String?       @map("tipo_material") @db.VarChar(30) // PAPEL, TINTA, VERNIZ, COLA, FACA, OUTRO
  quantidadeLiberada  Decimal       @default(0) @map("quantidade_liberada") @db.Decimal(12, 4)
  quantidadeConsumida Decimal       @default(0) @map("quantidade_consumida") @db.Decimal(12, 4)
  quantidadeDevolvida Decimal       @default(0) @map("quantidade_devolvida") @db.Decimal(12, 4)
  quantidadePerda     Decimal       @default(0) @map("quantidade_perda") @db.Decimal(12, 4)
  status              String        @default("PENDENTE") @db.VarChar(20) // PENDENTE, PARCIAL, LIBERADO, CONSUMIDO
  empresaId           String?       @map("empresa_id")

  itensLiberacao ItemLiberacao[]

  @@map("item_ordem_producao")
}

model EtapaOrdemProducao {
  id                     String           @id @default(uuid())
  ordemProducaoId        String           @map("ordem_producao_id")
  ordemProducao          OrdemProducao    @relation(fields: [ordemProducaoId], references: [id], onDelete: Cascade)
  sequencia              Int
  descricao              String           @db.VarChar(200)
  centroProducaoId       String?          @map("centro_producao_id")
  centroProducao         CentroProducao?  @relation(fields: [centroProducaoId], references: [id])
  tempoSetupMinutos      Decimal          @default(0) @map("tempo_setup_minutos") @db.Decimal(10, 2)
  tempoOperacaoCalculado Decimal          @default(0) @map("tempo_operacao_calculado") @db.Decimal(10, 2)
  tempoEsperaMinutos     Decimal          @default(0) @map("tempo_espera_minutos") @db.Decimal(10, 2)
  recursoId              String?          @map("recurso_id")
  recurso                RecursoProducao? @relation(fields: [recursoId], references: [id])
  status                 String           @default("PENDENTE") @db.VarChar(20) // PENDENTE, EM_ANDAMENTO, CONCLUIDA, PAUSADA
  dataInicioPrevista     DateTime?        @map("data_inicio_prevista")
  dataFimPrevista        DateTime?        @map("data_fim_prevista")
  dataInicioReal         DateTime?        @map("data_inicio_real")
  dataFimReal            DateTime?        @map("data_fim_real")
  // Campos operacionais
  funcionarioId          String?          @map("funcionario_id")
  quantidadePrevista     Decimal          @default(0) @map("quantidade_prevista") @db.Decimal(12, 4)
  quantidadeProduzida    Decimal          @default(0) @map("quantidade_produzida_etapa") @db.Decimal(12, 4)
  quantidadePerda        Decimal          @default(0) @map("quantidade_perda_etapa") @db.Decimal(12, 4)
  observacaoOperador     String?          @map("observacao_operador") @db.Text
  posicaoFila            Int?             @map("posicao_fila")

  apontamentosEtapa ApontamentoEtapa[]

  @@map("etapa_ordem_producao")
}

// Apontamentos granulares por etapa (contagem, perdas, paradas)
model ApontamentoEtapa {
  id                   String             @id @default(uuid())
  etapaOrdemProducaoId String             @map("etapa_ordem_producao_id")
  etapaOrdemProducao   EtapaOrdemProducao @relation(fields: [etapaOrdemProducaoId], references: [id], onDelete: Cascade)
  empresaId            String             @map("empresa_id")
  funcionarioId        String?            @map("funcionario_id")
  tipo                 String             @db.VarChar(20) // PRODUCAO, PERDA, PARADA, RETOMADA
  quantidadeProduzida  Decimal            @default(0) @map("quantidade_produzida") @db.Decimal(12, 4)
  quantidadePerda      Decimal            @default(0) @map("quantidade_perda") @db.Decimal(12, 4)
  motivoPerda          String?            @map("motivo_perda") @db.VarChar(50) // ACERTO, REFUGO, DEFEITO, APARA
  motivoParada         String?            @map("motivo_parada") @db.VarChar(50) // MANUTENCAO, FALTA_MATERIAL, ACERTO_MAQUINA, TROCA_TURNO, OUTRO
  tempoParadaMinutos   Int?               @map("tempo_parada_minutos")
  observacao           String?            @db.Text
  dataHora             DateTime           @default(now()) @map("data_hora")

  @@index([etapaOrdemProducaoId])
  @@index([empresaId, dataHora])
  @@map("apontamento_etapa")
}

model ApontamentoProducao {
  id                   String         @id @default(uuid())
  empresaId            String         @map("empresa_id")
  ordemProducaoId      String         @map("ordem_producao_id")
  ordemProducao        OrdemProducao  @relation(fields: [ordemProducaoId], references: [id])
  etapaOrdemProducaoId String?        @map("etapa_ordem_producao_id")
  centroProducaoId     String         @map("centro_producao_id")
  centroProducao       CentroProducao @relation(fields: [centroProducaoId], references: [id])
  quantidadeProduzida  Decimal        @map("quantidade_produzida") @db.Decimal(12, 4)
  quantidadeRejeitada  Decimal        @default(0) @map("quantidade_rejeitada") @db.Decimal(12, 4)
  dataInicio           DateTime       @map("data_inicio")
  dataFim              DateTime       @map("data_fim")
  tempoProducaoMinutos Decimal        @map("tempo_producao_minutos") @db.Decimal(10, 2)
  funcionarioId        String?        @map("funcionario_id")
  observacoes          String?        @db.Text
  criadoEm             DateTime       @default(now()) @map("criado_em")

  @@index([empresaId, ordemProducaoId])
  @@map("apontamento_producao")
}

model LiberacaoMaterial {
  id                      String        @id @default(uuid())
  empresaId               String        @map("empresa_id")
  numero                  Int
  ordemProducaoId         String        @map("ordem_producao_id")
  ordemProducao           OrdemProducao @relation(fields: [ordemProducaoId], references: [id])
  centroProducaoDestinoId String        @map("centro_producao_destino_id")
  tipo                    String        @db.VarChar(10) // TOTAL, PARCIAL
  status                  String        @default("PENDENTE") @db.VarChar(20) // PENDENTE, SEPARANDO, SEPARADA, ENTREGUE, CANCELADA
  dataLiberacao           DateTime      @default(now()) @map("data_liberacao")
  dataEntrega             DateTime?     @map("data_entrega")
  usuarioId               String        @map("usuario_id")
  observacoes             String?       @db.Text
  criadoEm                DateTime      @default(now()) @map("criado_em")

  itens ItemLiberacao[]

  @@unique([empresaId, numero])
  @@map("liberacao_material")
}

model ItemLiberacao {
  id                   String            @id @default(uuid())
  liberacaoMaterialId  String            @map("liberacao_material_id")
  liberacaoMaterial    LiberacaoMaterial @relation(fields: [liberacaoMaterialId], references: [id], onDelete: Cascade)
  itemOrdemProducaoId  String            @map("item_ordem_producao_id")
  itemOrdemProducao    ItemOrdemProducao @relation(fields: [itemOrdemProducaoId], references: [id])
  produtoId            String            @map("produto_id")
  quantidadeSolicitada Decimal           @map("quantidade_solicitada") @db.Decimal(12, 4)
  quantidadeSeparada   Decimal           @default(0) @map("quantidade_separada") @db.Decimal(12, 4)
  quantidadeEntregue   Decimal           @default(0) @map("quantidade_entregue") @db.Decimal(12, 4)

  @@map("item_liberacao")
}

model LogOrdemProducao {
  id              String        @id @default(uuid())
  ordemProducaoId String        @map("ordem_producao_id")
  ordemProducao   OrdemProducao @relation(fields: [ordemProducaoId], references: [id], onDelete: Cascade)
  statusAnterior  String        @map("status_anterior") @db.VarChar(20)
  statusNovo      String        @map("status_novo") @db.VarChar(20)
  usuarioId       String        @map("usuario_id")
  observacao      String?       @db.Text
  criadoEm        DateTime      @default(now()) @map("criado_em")

  @@index([ordemProducaoId])
  @@map("log_ordem_producao")
}


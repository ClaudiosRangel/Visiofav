  resultado           String           @db.VarChar(20) // CONFORME, DIVERGENTE
  tipoDivergencia     String?          @map("tipo_divergencia") @db.VarChar(20) // FALTA, EXCESSO, PRODUTO_ERRADO
  observacao          String?          @db.Text


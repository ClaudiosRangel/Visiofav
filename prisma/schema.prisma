  @@map("nota_entrada")
}

model ItemNotaEntrada {
  id              String   @id @default(uuid())
  notaEntradaId   String   @map("nota_entrada_id")
  notaEntrada     NotaEntrada @relation(fields: [notaEntradaId], references: [id], onDelete: Cascade)
  item            Int
  descricao       String   @db.VarChar(200)
  codigoProduto   String?  @db.VarChar(60) @map("codigo_produto")
  unidade         String   @db.VarChar(6)
  quantidade      Decimal  @db.Decimal(12,4)
  lote            String?  @db.VarChar(30)
  validade        DateTime?

  @@map("item_nota_entrada")
}


// ============================================================================
// WMS — ORDENS DE SERVIÇO OPERACIONAIS
// ============================================================================

model OrdemServicoWms {
  id              String   @id @default(uuid())
  empresaId       String   @map("empresa_id")
  numero          Int
  tipo            String   @db.VarChar(20) // ENTRADA, SAIDA, TRANSFERENCIA, MANUTENCAO
  operacao        String   @db.VarChar(20) // CONFERENCIA, ENDERECAMENTO, SEPARACAO, REPOSICAO, MUDANCA_ENDERECO, INVENTARIO
  status          String   @default("ABERTO") @db.VarChar(20) // ABERTO, EXECUTANDO, PARCIAL, CONCLUIDO, REJEITADO
  notaEntradaId   String?  @map("nota_entrada_id")
  agendaWmsId     String?  @map("agenda_wms_id")
  funcionarioId   String?  @map("funcionario_id") // funcionário principal (compat)
  ondaSeparacaoId String?  @map("onda_separacao_id")
  carregamentoId  String?  @map("carregamento_id")
  dataAbertura    DateTime @default(now()) @map("data_abertura")
  horaInicio      DateTime? @map("hora_inicio")
  horaFim         DateTime? @map("hora_fim")
  observacao      String?  @db.Text
  criadoEm        DateTime @default(now()) @map("criado_em")
  atualizadoEm    DateTime @updatedAt @map("atualizado_em")

  ondaSeparacao   OndaSeparacao?  @relation(fields: [ondaSeparacaoId], references: [id])
  carregamento    Carregamento?   @relation(fields: [carregamentoId], references: [id])
  funcionarios    OsFuncionarioWms[]
  fichasOperacionais FichaOperacional[]

  @@unique([empresaId, numero])
  @@map("ordem_servico_wms")
}

model OsFuncionarioWms {
  id              String   @id @default(uuid())
  ordemServicoId  String   @map("ordem_servico_id")
  ordemServico    OrdemServicoWms @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  funcionarioId   String   @map("funcionario_id")
  horaInicio      DateTime? @map("hora_inicio")
  horaFim         DateTime? @map("hora_fim")
  criadoEm        DateTime @default(now()) @map("criado_em")

  @@map("os_funcionario_wms")
}


// ============================================================================
// WMS — LOG DE MOVIMENTAÇÕES DE ESTOQUE
// ============================================================================

model Sku {
  id            String   @id @default(uuid())
  produtoId     String   @map("produto_id")
  sequencia     Int
  descricao     String?  @db.VarChar(200)
  codigoBarra   String?  @db.VarChar(30) @map("codigo_barra")
  unidade       String   @db.VarChar(6)
  qtdEmbalagem  Int      @default(1) @map("qtd_embalagem")
  largura       Decimal? @db.Decimal(10,3)
  altura        Decimal? @db.Decimal(10,3)
  comprimento   Decimal? @db.Decimal(10,3)
  volume        Decimal? @db.Decimal(10,6)
  pesoLiquido   Decimal? @db.Decimal(10,3) @map("peso_liquido")
  pesoBruto     Decimal? @db.Decimal(10,3) @map("peso_bruto")
  pesoPalete    Decimal? @db.Decimal(10,3) @map("peso_palete")
  lastro        Int?
  camada        Int?
  tipoPalete    String?  @db.VarChar(30) @map("tipo_palete")
  status        Boolean  @default(true)
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")

  @@map("sku")
}

model LogMovimentacao {
  id            String   @id @default(uuid())
  empresaId     String   @map("empresa_id")
  produtoId     String   @map("produto_id")
  enderecoId    String   @map("endereco_id")
  tipo          String   @db.VarChar(30) // AJUSTE_ENTRADA, AJUSTE_SAIDA, INVENTARIO, AVARIA, VENCIMENTO, ENDERECAMENTO, TRANSFERENCIA
  quantidade    Decimal  @db.Decimal(12,4)
  saldoAnterior Decimal  @db.Decimal(12,4) @map("saldo_anterior")
  saldoNovo     Decimal  @db.Decimal(12,4) @map("saldo_novo")
  motivo        String?  @db.Text
  usuarioId     String   @map("usuario_id")
  criadoEm      DateTime @default(now()) @map("criado_em")

  @@index([empresaId, criadoEm])
  @@index([produtoId])
  @@index([enderecoId])
  @@map("log_movimentacao")
}


// ============================================================================
// WMS — INVENTÁRIO
// ============================================================================

model Inventario {
  id            String   @id @default(uuid())
  empresaId     String   @map("empresa_id")
  numero        Int
  tipo          String   @default("GERAL") @db.VarChar(20) // GERAL, PARCIAL, CICLICO
  status        String   @default("ABERTO") @db.VarChar(20) // ABERTO, EM_CONTAGEM, CONCLUIDO, CANCELADO
  zonaId        String?  @map("zona_id")
  rua           String?  @db.VarChar(10)
  observacao    String?  @db.Text
  criadoPorId   String   @map("criado_por_id")
  criadoEm      DateTime @default(now()) @map("criado_em")
  concluidoEm   DateTime? @map("concluido_em")

  itens         ItemInventario[]

  @@unique([empresaId, numero])
  @@map("inventario")
}

model ItemInventario {
  id              String   @id @default(uuid())
  inventarioId    String   @map("inventario_id")
  inventario      Inventario @relation(fields: [inventarioId], references: [id], onDelete: Cascade)
  enderecoId      String   @map("endereco_id")
  produtoId       String   @map("produto_id")
  saldoSistema    Decimal  @db.Decimal(12,4) @map("saldo_sistema")
  saldoContado    Decimal? @db.Decimal(12,4) @map("saldo_contado")
  divergencia     Decimal? @db.Decimal(12,4)
  status          String   @default("PENDENTE") @db.VarChar(20) // PENDENTE, CONTADO, CONFORME, DIVERGENTE
  ajusteAplicado  Boolean  @default(false) @map("ajuste_aplicado")
  contadoEm       DateTime? @map("contado_em")

  @@map("item_inventario")
}


// ============================================================================
// WMS — FICHAS OPERACIONAIS
// ============================================================================

model FichaOperacional {
  id              String   @id @default(uuid())
  empresaId       String   @map("empresa_id")
  empresa         Empresa  @relation(fields: [empresaId], references: [id])
  tipo            String   @db.VarChar(20) // SEPARACAO, EMBALAGEM, CARREGAMENTO, ENDERECAMENTO, CONFERENCIA
  referenciaId    String   @map("referencia_id") // ondaSeparacaoId, carregamentoId, notaEntradaId
  ordemServicoId  String?  @map("ordem_servico_id")
  ordemServico    OrdemServicoWms? @relation(fields: [ordemServicoId], references: [id])
  codigoBarras    String   @unique @db.VarChar(30) @map("codigo_barras")
  status          String   @default("GERADA") @db.VarChar(20) // GERADA, IMPRESSA, DIGITALIZADA, CONFIRMADA
  dadosOcr        String?  @db.Text @map("dados_ocr") // JSON com resultado OCR
  origemDados     String?  @db.VarChar(10) @map("origem_dados") // MANUAL, OCR, SCANNER
  criadoEm        DateTime @default(now()) @map("criado_em")
  atualizadoEm    DateTime @updatedAt @map("atualizado_em")

  @@index([empresaId, tipo])
  @@index([referenciaId])
  @@map("ficha_operacional")
}


// ============================================================================
// WMS — AUDITORIA
// ============================================================================

model AuditLog {
  id          String   @id @default(uuid())
  empresaId   String   @map("empresa_id")
  entidade    String   @db.VarChar(50) // ESTOQUE, CONFERENCIA, ENDERECAMENTO, SEPARACAO, CARREGAMENTO, INVENTARIO
  entidadeId  String   @db.VarChar(36) @map("entidade_id")
  acao        String   @db.VarChar(30) // CRIAR, ATUALIZAR, EXCLUIR, CONFERIR, APROVAR, REJEITAR, TRANSFERIR
  descricao   String   @db.Text
  dados       String?  @db.Text // JSON com dados relevantes
  usuarioId   String   @map("usuario_id")
  ip          String?  @db.VarChar(45)
  criadoEm    DateTime @default(now()) @map("criado_em")

  @@index([empresaId, criadoEm])
  @@index([entidade, entidadeId])
  @@index([usuarioId])
  @@map("audit_log")
}


// ============================================================================
// WMS — DADOS LOGÍSTICOS DO PRODUTO
// ============================================================================

model DadosLogisticosArmazenagem {
  id              String   @id @default(uuid())
  produtoId       String   @map("produto_id")
  skuSeq          Int      @map("sku_seq")
  sequencia       Int
  enderecoFixoId  String?  @map("endereco_fixo_id")
  tipoNorma       String   @default("FEFO") @db.VarChar(10) // FEFO, FIFO, LIFO
  pulmaoRegulador Int      @default(0) @map("pulmao_regulador")
  nivelMinPP      Int      @default(0) @map("nivel_min_pp")
  nivelMaxPP      Int      @default(0) @map("nivel_max_pp")
  nivelMaxBlocado Int      @default(0) @map("nivel_max_blocado")
  fixo            Boolean  @default(false)
  criadoEm        DateTime @default(now()) @map("criado_em")
  atualizadoEm    DateTime @updatedAt @map("atualizado_em")

  @@map("dados_logisticos_armazenagem")
}

model DadosLogisticosPicking {
  id                    String   @id @default(uuid())
  produtoId             String   @map("produto_id")
  skuSeq                Int      @map("sku_seq")
  sequencia             Int
  enderecoPickingId     String?  @map("endereco_picking_id")
  tipoPicking           String   @default("NORMAL") @db.VarChar(20) // NORMAL, FLOW_RACK
  capacidade            Decimal  @default(0) @db.Decimal(12,4)
  pontoReposicao        Decimal  @default(0) @db.Decimal(12,4) @map("ponto_reposicao")
  pontoReposicaoPercent Decimal  @default(0) @db.Decimal(5,2) @map("ponto_reposicao_percent")
  pontoReposicaoDias    Int      @default(0) @map("ponto_reposicao_dias")
  criadoEm              DateTime @default(now()) @map("criado_em")
  atualizadoEm          DateTime @updatedAt @map("atualizado_em")

  @@map("dados_logisticos_picking")
}

model DadosLogisticosExpedicao {
  id                      String   @id @default(uuid())
  produtoId               String   @map("produto_id")
  skuSeq                  Int      @map("sku_seq")
  fracionado              Boolean  @default(false)
  absorbePaleteFechado    Boolean  @default(false) @map("absorbe_palete_fechado")
  absorbePaleteFechadoCx  Boolean  @default(false) @map("absorbe_palete_fechado_cx")
  tipoProduto             String?  @db.VarChar(20) @map("tipo_produto")
  tipoCargaId             String?  @map("tipo_carga_id")
  criadoEm                DateTime @default(now()) @map("criado_em")
  atualizadoEm            DateTime @updatedAt @map("atualizado_em")

  @@map("dados_logisticos_expedicao")
}

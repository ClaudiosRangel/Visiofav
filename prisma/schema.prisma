model Deposito {
  id                    String   @id @default(uuid())
  centroDistribuicaoId  String   @map("centro_distribuicao_id")
  descricao             String   @db.VarChar(150)
  cidade                String?  @db.VarChar(100)
  uf                    String?  @db.VarChar(2)
  status                Boolean  @default(true)
  criadoEm              DateTime @default(now()) @map("criado_em")

  zonas     Zona[]
  enderecos Endereco[]
  docas     Doca[]

  @@map("deposito")
}

model Zona {
  id          String   @id @default(uuid())
  descricao   String   @db.VarChar(150)
  depositoId  String?  @map("deposito_id")
  deposito    Deposito? @relation(fields: [depositoId], references: [id])
  status      Boolean  @default(true)
  criadoEm    DateTime @default(now()) @map("criado_em")

  enderecos   Endereco[]

  @@map("zona")
}

model Estrutura {
  id          String   @id @default(uuid())
  codigo      Int      @default(autoincrement())
  descricao   String   @db.VarChar(150)
  tipo        String   @db.VarChar(30) // PORTA_PALETE, BLOCADO, DRIVE_IN, FLOW_RACK
  capacidade  Decimal? @db.Decimal(10,3)  // max weight in kg
  largura     Decimal? @db.Decimal(10,3)  // width in meters
  altura      Decimal? @db.Decimal(10,3)  // height in meters
  comprimento Decimal? @db.Decimal(10,3)  // depth in meters
  cubagem     Decimal? @db.Decimal(10,6)  // max volume in m³ (auto-calculated: largura × altura × comprimento)
  status      Boolean  @default(true)
  criadoEm    DateTime @default(now()) @map("criado_em")

  enderecos   Endereco[]

  @@map("estrutura")
}

model Endereco {
  id                      String   @id @default(uuid())
  codigoDeposito          String?  @db.VarChar(10) @map("codigo_deposito")
  codigoZona              String?  @db.VarChar(10) @map("codigo_zona")
  codigoRua               String?  @db.VarChar(10) @map("codigo_rua")
  codigoPredio            String?  @db.VarChar(10) @map("codigo_predio")
  codigoNivel             String?  @db.VarChar(10) @map("codigo_nivel")
  codigoApto              String?  @db.VarChar(10) @map("codigo_apto")
  enderecoCompleto        String?  @db.VarChar(60) @map("endereco_completo")
  tipo                    String   @default("ARMAZENAGEM") @db.VarChar(20) // ARMAZENAGEM, PICKING, DOCA, LIVRE, BLOQUEADO
  codigoBarras            String?  @db.VarChar(30) @map("codigo_barras")
  areaArmazenagem         String?  @db.VarChar(20) @map("area_armazenagem") // PULMAO, PICKING
  centroDistribuicaoId    String?  @map("centro_distribuicao_id")
  depositoId              String?  @map("deposito_id")
  deposito                Deposito? @relation(fields: [depositoId], references: [id])
  zonaId                  String?  @map("zona_id")
  zona                    Zona?    @relation(fields: [zonaId], references: [id])
  estruturaId             String?  @map("estrutura_id")
  estrutura               Estrutura? @relation(fields: [estruturaId], references: [id])
  formaArmazenagemId      String?  @map("forma_armazenagem_id")
  formaArmazenagem        FormaArmazenagem? @relation(fields: [formaArmazenagemId], references: [id])
  ambienteArmazenagemId   String?  @map("ambiente_armazenagem_id")
  ambienteArmazenagem     AmbienteArmazenagem? @relation(fields: [ambienteArmazenagemId], references: [id])
  classificacaoProdutoId  String?  @map("classificacao_produto_id")
  classificacaoProduto    ClassificacaoProduto? @relation(fields: [classificacaoProdutoId], references: [id])
  status                  Boolean  @default(true)
  criadoEm                DateTime @default(now()) @map("criado_em")

  saldos                  SaldoEndereco[]

  @@map("endereco")
}

model SaldoEndereco {
  id            String   @id @default(uuid())
  enderecoId    String   @map("endereco_id")

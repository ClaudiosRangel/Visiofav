# VisioFab WMS Backend — Environment Variables
# Copy to .env and fill in the values

# PostgreSQL connection string (Neon free tier: https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT secret for authentication (generate a strong random string)
JWT_SECRET="change-me-to-a-strong-random-secret"

# Server port
PORT=3333

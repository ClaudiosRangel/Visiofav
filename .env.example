# VisioFab WMS Backend — Environment Variables
# Copy to .env and fill in the values

# PostgreSQL connection string (Neon free tier: https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT secret for authentication (generate a strong random string — OBRIGATÓRIO em produção)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-strong-random-secret"

# Server port
PORT=3333

# Firebase Auth (período de migração — opcional)
# FIREBASE_AUTH_ENABLED=true
# FIREBASE_PROJECT_ID=your-firebase-project-id

# Node environment (production | development)
# NODE_ENV=production

# Persistent storage path (Render Persistent Disk mount path)
# Em produção no Render, configurar para o mount path do disco persistente (ex: /var/data)
# Em desenvolvimento local, deixar vazio (usa o diretório do projeto)
# PERSISTENT_STORAGE_PATH=/var/data

# ═══════════════════════════════════════════════════════════════
# Módulo Fiscal
# ═══════════════════════════════════════════════════════════════

# Chave de criptografia para certificados digitais (PFX em repouso)
# Mínimo 32 caracteres (AES-256). OBRIGATÓRIA para usar o módulo fiscal.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FISCAL_CERT_ENCRYPTION_KEY="change-me-generate-a-64-char-hex-key-with-crypto-randomBytes"

# Ambiente SEFAZ: 1 = Produção, 2 = Homologação (padrão: 2)
SEFAZ_AMBIENTE=2

# Timeout de comunicação com a SEFAZ em milissegundos (padrão: 30000, range: 5000–120000)
SEFAZ_TIMEOUT_MS=30000

# Tamanho máximo da fila de contingência — documentos pendentes (padrão: 500)
CONTINGENCIA_MAX_FILA=500

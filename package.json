{
  "name": "visiofab-wms-back",
  "version": "1.0.0",
  "description": "VisioFab WMS - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "echo 'build-v2' && npx prisma generate",
    "start": "(npx tsx prisma/migrate-prod.ts || true) && tsx src/server.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.39.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^11.0.0",
    "@prisma/client": "^6.2.1",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.10.1",
    "fast-xml-parser": "^5.9.3",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-forge": "^1.4.0",
    "nodemailer": "^9.0.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^4.0.379",
    "prisma": "^6.2.1",
    "tesseract.js": "^5.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "xml-crypto": "^6.1.2",
    "zod": "^3.24.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.7",
    "@types/node-forge": "^1.3.14",
    "@vitest/coverage-v8": "^4.1.6",
    "fast-check": "^4.8.0",
    "pdfkit": "^0.19.1",
    "vitest": "^4.1.6"
  }
}
